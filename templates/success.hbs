<div class="card shell-card-md shadow-sm border-0 mx-auto text-center w-100" hx-boost="true" hx-target="#main-content">
    <div class="card-body p-3">
    <div class="mb-2">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle text-bg-primary"
             style="width: 50px; height: 50px;">
            <img src="/static/img/icons/check-lg.svg"
                 alt=""
                 width="28"
                 height="28">
        </div>
    </div>
    <h2 class="card-title mb-3 fw-bold text-primary fs-2">Abgabe Erfolgreich!</h2>
    <div class="text-start p-3 rounded-4 bg-body-tertiary">
        <div class="row g-2">
            <div class="col-12 pb-2 border-bottom border-light">
                <span class="d-block text-uppercase fw-bold small">Dateiname</span>
                <span class="fw-bold text-break fs-5">{{filename}}</span>
            </div>
            <div class="col-md-6 pb-1">
                <span class="d-block text-uppercase fw-bold small">Größe</span>
                <span class="fs-6">{{filesize}} Bytes</span>
            </div>
            <div class="col-md-6 pb-1">
                <span class="d-block text-uppercase fw-bold small">Dauer</span>
                <span class="fs-6">{{duration_seconds}} Sekunden</span>
            </div>
            <div class="col-md-6 pb-1">
                <span class="d-block text-uppercase fw-bold small">IP</span>
                <span class="fs-6">{{remote_ip}}</span>
            </div>
            <div class="col-12 pt-2 border-top border-light">
                <span class="d-block text-uppercase fw-bold small">MD5-Summe</span>
                <span class="font-monospace text-break small">{{md5sum}}</span>
            </div>
        </div>
    </div>
    </div>
    <div class="card-footer bg-transparent border-0 text-center pt-0 pb-3">
        <a href="/"
            class="btn btn-primary px-4 py-2">Zurück zur Startseite</a>
    </div>
</div>
