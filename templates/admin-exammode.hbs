<form hx-post="/api/exammode"
      hx-trigger="change"
      hx-target="this"
      hx-swap="outerHTML"
      class="shell-form-md mx-auto">
    <div class="card shadow-sm {{#if internet_active}}border-success-subtle bg-success-subtle{{else}}border-danger-subtle bg-danger-subtle{{/if}}">
        <div class="card-header bg-transparent border-0 text-center pt-4 pb-0">
            <h3 class="card-title fw-bold fs-5 mb-1">Dokumentationsserver-Firewall-Regel</h3>
            <p class="card-text small mb-0">Schaltet den Internetzugang für die Prüfungsumgebung während des Betriebs um.</p>
        </div>
        <div class="card-body d-flex flex-column align-items-center text-center gap-3 pt-3">
            <div class="form-check form-switch m-0 d-flex justify-content-center">
                <input id="internet_active"
                       name="internet_active"
                       type="checkbox"
                       role="switch"
                       class="form-check-input mt-0 {{#if internet_active}}bg-success border-success{{else}}bg-danger border-danger{{/if}}"
                       style="width: 3.5rem; height: 1.75rem;"
                       {{#if internet_active}}checked{{/if}}>
            </div>
            <div class="badge rounded-pill px-3 py-2 fs-6 {{#if internet_active}}text-bg-success{{else}}text-bg-danger{{/if}}">
                {{#if internet_active}}Internet aktiv{{else}}Internet blockiert{{/if}}
            </div>
            <p class="small mb-0">
                {{#if internet_active}}Die Firewall-Regel ist deaktiviert. Voller Internetzugang ist freigegeben.{{else}}Die Firewall-Regel ist aktiviert. Internetzugang ist gesperrt.{{/if}}
            </p>
            <div class="htmx-indicator small">Firewall-Regel wird aktualisiert ...</div>
        </div>
    </div>
</form>
