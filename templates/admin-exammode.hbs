<form hx-post="/api/exammode"
      hx-trigger="change"
      hx-target="this"
      hx-swap="outerHTML"
      class="mx-auto"
      style="max-width: 640px;">
    <div class="rounded-4 border p-4 {{#if internet_active}}border-success-subtle bg-success-subtle{{else}}border-danger-subtle bg-danger-subtle{{/if}}">
        <div class="d-flex flex-column align-items-center text-center gap-3">
            <div>
                <div class="fw-bold fs-5 mb-1">Dokumentationsserver-Firewall-Regel</div>
                <div class="text-muted small">Schaltet den Internetzugang für die Prüfungsumgebung während des Betriebs um.</div>
            </div>
            <div class="form-check form-switch m-0 d-flex justify-content-center justify-center">
                <input id="internet_active"
                       name="internet_active"
                       type="checkbox"
                       role="switch"
                       class="form-check-input mt-0 {{#if internet_active}}bg-success border-success{{else}}bg-danger border-danger{{/if}}"
                       style="width: 3.5rem; height: 1.75rem;"
                       {{#if internet_active}}checked{{/if}}>
            </div>
        </div>
        <div class="mt-3 fw-bold fs-5 {{#if internet_active}}text-success{{else}}text-danger{{/if}}">
            {{#if internet_active}}Internet aktiv{{else}}Internet blockiert{{/if}}
        </div>
        <div class="small text-muted">
            {{#if internet_active}}Die Firewall-Regel ist deaktiviert. Voller Internetzugang ist freigegeben.{{else}}Die Firewall-Regel ist aktiviert. Internetzugang ist gesperrt.{{/if}}
        </div>
        <div class="htmx-indicator small mt-2 text-muted">Firewall-Regel wird aktualisiert ...</div>
    </div>
</form>
