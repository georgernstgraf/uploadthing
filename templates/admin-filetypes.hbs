<section class="card shadow-sm border-0 mx-auto" style="max-width: 840px;">
    <div class="card-header bg-transparent border-0 text-center pt-4 pb-0">
        <h2 class="card-title fs-4 mb-2">Admin</h2>
    </div>
    <div class="card-body py-3 px-3">

    <div class="vstack gap-3 mx-auto" style="max-width: 720px;">
        <section class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                    <div>
                        <h3 class="h5 mb-1">Theme</h3>
                    </div>
                </div>

                <form action="/admin/theme"
                      method="post"
                      class="mx-auto"
                      style="max-width: 640px;">
                    <label class="form-label fw-bold" for="theme">Auswahl</label>
                    <div class="row g-2 align-items-end">
                        <div class="col-md-8">
                            <select id="theme"
                                    name="theme"
                                    class="form-select form-select-lg"
                                    required>
                                {{#unless current_theme_key}}
                                    <option value="" selected disabled>Bitte Theme auswählen</option>
                                {{/unless}}
                                {{#each available_themes}}
                                    <option value="{{this.key}}" {{#if (eq this.key ../current_theme_key)}}selected{{/if}}>{{this.label}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="col-md-4 d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Theme anwenden</button>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        <section class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                    <div>
                        <h3 class="h5 mb-1">Dokumentationsserver-Firewall-Regel</h3>
                    </div>
                </div>
                <div>
                    {{{firewall_toggle_html}}}
                </div>
            </div>
        </section>

        <section class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                    <div>
                        <h3 class="h5 mb-1">Abgaben-Verzeichnis</h3>
                    </div>
                </div>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/admin/download-abgaben" class="btn btn-primary btn-lg fw-bold px-4 py-2 shadow-sm" download>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-archive me-2" viewBox="0 0 16 16">
                            <path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 2 12.5V5a1 1 0 0 1-1-1zm2 3v7.5A1.5 1.5 0 0 0 4.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5zm13-3H1v2h14zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
                        </svg>
                        Abgaben &amp; Datenbank herunterladen (TAR.GZ)
                    </a>
                    <button hx-post="/admin/wipe-abgaben"
                            hx-confirm="Sind Sie sicher, dass Sie ALLE Abgaben unwiderruflich löschen möchten?"
                            hx-target="#wipe-result"
                            class="btn btn-warning btn-lg fw-bold px-4 py-2 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-trash3 me-2" viewBox="0 0 16 16">
                            <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                        </svg>
                        Abgaben-Verzeichnis leeren
                    </button>
                </div>
                <div id="wipe-result" class="mt-3"></div>
            </div>
        </section>

        <section class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                    <div>
                        <h3 class="h5 mb-1">Erlaubte Dateitypen</h3>
                    </div>
                </div>

                <form hx-post="/admin/filetypes"
                      hx-target="#main-content"
                      hx-swap="innerHTML"
                      class="mx-auto"
                      style="max-width: 640px;">
                    <label class="form-label fw-bold" for="permitted_filetypes">Dateiendungen (kommagetrennt)</label>
                    <input id="permitted_filetypes"
                           name="permitted_filetypes"
                           type="text"
                           class="form-control form-control-lg text-center"
                           value="{{permitted_filetypes}}"
                           placeholder="zip, md, pdf"
                           autocomplete="off"
                           required>
                    <div class="form-text text-center mb-3">Punkte sind optional. Beispiel: zip, md, pdf</div>
                    <div class="d-grid">
                        <button type="submit"
                                class="btn btn-info btn-lg">Dateitypen speichern</button>
                    </div>
                </form>

                <div class="mt-4 text-center">
                    <div class="small text-uppercase mb-1" style="letter-spacing: 0.1em;">Aktiv</div>
                    <div class="fs-5 fw-bold">
                        {{#each current_filetypes}}
                            {{#if @index}}, {{/if}}.{{this}}
                        {{/each}}
                    </div>
                </div>
            </div>
        </section>
    </div>

    {{#if success_message}}
        <div class="alert alert-success mx-auto mt-3 mb-0" style="max-width: 720px;">{{success_message}}</div>
    {{/if}}
    {{#if error_message}}
        <div class="alert alert-danger mx-auto mt-3 mb-0" style="max-width: 720px;">{{error_message}}</div>
    {{/if}}
    </div>
</section>
