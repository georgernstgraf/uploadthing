<section class="leisure-card mx-auto mw-800 py-3 px-3">
    <div class="text-center mb-3">
        <h2 class="fs-2xl mb-2">Erlaubte Dateitypen</h2>
        <p class="text-muted mb-0">Lehrende können die erlaubten Endungen während des Betriebs anpassen.</p>
    </div>

    {{#if success_message}}
        <div class="alert alert-success mx-auto mb-3" style="max-width: 640px;">{{success_message}}</div>
    {{/if}}
    {{#if error_message}}
        <div class="alert alert-danger mx-auto mb-3" style="max-width: 640px;">{{error_message}}</div>
    {{/if}}

    <form hx-post="/admin/filetypes"
          hx-target="#main-content"
          hx-swap="innerHTML"
          class="mx-auto"
          style="max-width: 640px;">
        <label class="form-label fw-bold" for="permitted_filetypes">Dateiendungen (kommagetrennt)</label>
        <input id="permitted_filetypes"
               name="permitted_filetypes"
               type="text"
               class="form-control form-control-lg text-center"
               value="{{permitted_filetypes}}"
               placeholder="zip, md, pdf"
               autocomplete="off"
               required>
        <div class="form-text text-center mb-3">Punkte sind optional. Beispiel: zip, md, pdf</div>
        <div class="d-grid">
            <button type="submit"
                    class="btn btn-info btn-lg">Dateitypen speichern</button>
        </div>
    </form>

    <div class="mt-4 text-center">
        <div class="text-uppercase fs-sm ls-wide text-muted mb-1">Aktiv</div>
        <div class="fs-lg fw-bold">
            {{#each current_filetypes}}
                {{#if @index}}, {{/if}}.{{this}}
            {{/each}}
        </div>
    </div>
</section>
