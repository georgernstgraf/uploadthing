<!DOCTYPE html>
<html lang="de"
      data-bs-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">
    <title>{{page_title}}</title>
    <script>
        (function () {
            const themeAssetVersion = '{{theme_asset_version}}';
            const savedMode = localStorage.getItem('uploadthing-mode');
            const mode = savedMode === 'dark' ? 'dark' : 'light';
            const bg = mode === 'dark'
                ? `url('/static/img/bg-dark.jpg?v=${themeAssetVersion}')`
                : `url('/static/img/bg-light.jpg?v=${themeAssetVersion}')`;

            document.documentElement.setAttribute('data-bs-theme', mode);
            document.documentElement.style.setProperty('--app-background-image', bg);
        })();
    </script>
    <link rel="icon"
          type="image/svg+xml"
          href="/static/favicon.svg">
    <link rel="stylesheet"
          href="/static/ibm-plex-sans.css">
    <link rel="stylesheet"
          href="/static/bootstrap.css">
    <link rel="stylesheet"
          href="/static/ui-shell.css">
    <link rel="stylesheet"
          href="/static/theme.css?v={{theme_asset_version}}">
    <link rel="stylesheet"
          href="/static/bootstrap-overrides.css">
    <style>
        [x-cloak] {
            display: none !important;
        }

        #global-htmx-indicator {
            display: none;
        }

        body.htmx-request #global-htmx-indicator {
            display: block;
        }
    </style>
    <script src="/static/htmx.js"></script>
    <script src="/static/toast.js"></script>
    <script>
        function showNetworkErrorToast() {
            showToast('Der Server ist derzeit nicht erreichbar. Bitte versuchen Sie es erneut.', 'danger');
        }

        document.addEventListener('htmx:responseError', function(evt) {
            const xhr = evt.detail.xhr;
            if (xhr.status >= 400) {
                showToast(xhr.responseText || 'Ein Fehler ist aufgetreten', 'danger');
            }
        });

        document.addEventListener('htmx:sendError', function() {
            showNetworkErrorToast();
        });

        document.addEventListener('htmx:timeout', function() {
            showNetworkErrorToast();
        });

        document.addEventListener('htmx:afterSwap', function(evt) {
            if (evt.detail.target && evt.detail.target.id === 'main-content') {
                window.scrollTo({ top: 0, behavior: 'auto' });
            }
        });
    </script>
    <script src="/static/alpine.min.js"
            defer></script>
</head>

     <body>
    <header class="position-fixed top-0 start-0 end-0 z-3" style="backdrop-filter: blur(var(--CTBS-GlassBlur)); -webkit-backdrop-filter: blur(var(--CTBS-GlassBlur));">
        <div class="position-relative mx-2 mt-2">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body py-2 px-3 d-flex flex-row-reverse flex-sm-row flex-wrap flex-sm-nowrap align-items-center gap-2">
                <button
                        type="button"
                        aria-hidden="true"
                        tabindex="-1"
                        class="btn btn-sm btn-outline-secondary rounded-3 px-3 invisible pe-none"
                        disabled> Dunkel </button>
                <h1 class="mb-0 text-center text-body flex-grow-1 fs-2">http://{{page_title}}/</h1>
                <button id="theme-toggle"
                        type="button"
                        aria-label="Hell-Dunkel-Modus wechseln"
                        class="btn btn-sm btn-outline-info rounded-3 px-3">Dunkel</button>
                </div>
            </div>
        </div>
    </header>
    <script>
        (function () {
            const storageKey = 'uploadthing-mode';
            const themeAssetVersion = '{{theme_asset_version}}';
            const backgrounds = {
                light: `url('/static/img/bg-light.jpg?v=${themeAssetVersion}')`,
                dark: `url('/static/img/bg-dark.jpg?v=${themeAssetVersion}')`,
            };

            function setMode(mode) {
                const nextMode = mode === 'dark' ? 'dark' : 'light';
                const toggleBtn = document.getElementById('theme-toggle');

                document.documentElement.setAttribute('data-bs-theme', nextMode);
                document.documentElement.style.setProperty('--app-background-image', backgrounds[nextMode]);

                if (toggleBtn) {
                    toggleBtn.textContent = nextMode === 'light' ? 'Dunkel' : 'Hell';
                }

                localStorage.setItem(storageKey, nextMode);
            }

            const savedMode = localStorage.getItem(storageKey);
            setMode(savedMode === 'dark' ? 'dark' : 'light');

            window.addEventListener('load', () => {
                const toggleBtn = document.getElementById('theme-toggle');
                toggleBtn.addEventListener('click', () => {
                    const currentMode = document.documentElement.getAttribute('data-bs-theme');
                    setMode(currentMode === 'dark' ? 'light' : 'dark');
                });
            });
        })();
    </script>
    <script>
        (function () {
            let activeHtmxRequests = 0;

            function trackHtmxRequest(event) {
                const requestConfig = event.detail?.requestConfig;
                if (!requestConfig) {
                    return;
                }
                requestConfig._globalSpinnerTracked = true;
            }

            function untrackHtmxRequest(event) {
                const requestConfig = event.detail?.requestConfig;
                if (!requestConfig?._globalSpinnerTracked) {
                    return false;
                }
                requestConfig._globalSpinnerTracked = false;
                return true;
            }

            function updateGlobalIndicator() {
                document.body.classList.toggle('htmx-request', activeHtmxRequests > 0);
            }

            document.body.addEventListener('htmx:beforeRequest', function (event) {
                trackHtmxRequest(event);
                activeHtmxRequests += 1;
                updateGlobalIndicator();
            });

            document.body.addEventListener('htmx:abort', function (event) {
                if (!untrackHtmxRequest(event)) {
                    return;
                }
                activeHtmxRequests = Math.max(0, activeHtmxRequests - 1);
                updateGlobalIndicator();
            });

            document.body.addEventListener('htmx:afterRequest', function (event) {
                if (!untrackHtmxRequest(event)) {
                    return;
                }
                activeHtmxRequests = Math.max(0, activeHtmxRequests - 1);
                updateGlobalIndicator();
            });

            document.body.addEventListener('htmx:sendError', function (event) {
                if (!untrackHtmxRequest(event)) {
                    return;
                }
                activeHtmxRequests = Math.max(0, activeHtmxRequests - 1);
                updateGlobalIndicator();
            });

            document.body.addEventListener('htmx:responseError', function (event) {
                if (!untrackHtmxRequest(event)) {
                    return;
                }
                activeHtmxRequests = Math.max(0, activeHtmxRequests - 1);
                updateGlobalIndicator();
            });

            document.body.addEventListener('htmx:beforeRequest', function (event) {
                const trigger = event.detail?.elt;
                if (!trigger || !trigger.closest('#report')) {
                    return;
                }

                const hasOpenDetails = Boolean(document.querySelector('#report details[open]'));
                const anomalyAccordionOpen = Boolean(document.querySelector('#anomaly-collapse.show'));
                if (hasOpenDetails || anomalyAccordionOpen) {
                    if (untrackHtmxRequest(event)) {
                        activeHtmxRequests = Math.max(0, activeHtmxRequests - 1);
                        updateGlobalIndicator();
                    }
                    event.preventDefault();
                }
            });
        })();
    </script>
    {{> main}}
</body>

</html>
