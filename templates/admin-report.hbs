<section class="container"
         id="report"
         hx-get="/admin"
         hx-trigger="every {{admin_refresh_seconds}}s"
         hx-target="#report"
         hx-swap="innerHTML"
         hx-select="#report > *"
         hx-include="#timeselector form">
    <h2 class="text-center mb-0 fs-4">SchülerInnen und IP Adressen</h2>
    <h6 class="text-center mb-2 small"> Zeitraum: {{#unless withinTimeCutoff}}
            {{startdate}}
        {{/unless}}
        {{starttime}} - {{#if endtimeInFuture}} jetzt {{else}}
            <span x-show="showEndTime"
                  x-cloak>
                {{enddate}}
                {{endtime}}
            </span>
        {{/if}}
    </h6>
    <!-- Table 1: IPs with registered names -->
    <h5 class="text-center mt-2 mb-1 fw-bold text-uppercase border-bottom pb-1 d-inline-block mx-auto border-primary"
        style="letter-spacing: 0.05em;">Bekannte IP-Adressen</h5>
    <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3 g-1 mt-1">
        {{#each ips_with_name}}
            <div class="col">
                <details class="h-100 card shadow-sm  mb-0 d-flex flex-column">
                    <summary class="card-header bg-transparent border-0 fw-bold py-2 px-2">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <div class="d-flex align-items-center gap-1 overflow-hidden">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-bg-primary"
                                     style="width: 26px; height: 26px; font-size: 0.875rem;">
                                    {{#if this.cookie_presents.[0].user}}
                                        {{givenNameInitial this.cookie_presents.[0].user.name}}
                                    {{else}} ? {{/if}}
                                </div>
                                <div class="overflow-hidden">
                                    <span class="d-block text-truncate"
                                          title="{{this.cookie_presents.[0].user.name}}">
                                        {{#if this.cookie_presents.[0].user}}
                                            {{this.cookie_presents.[0].user.name}}
                                        {{else}} Unbekannt {{/if}}
                                    </span>
                                    <span class="fw-normal d-block text-truncate small">{{this.ip}}</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1 ms-1 flex-shrink-0">
                                <span
                                      class="badge {{#if this.is_stale}}text-bg-danger{{else}}bg-light text-dark border{{/if}} small text-wrap text-end">
                                    Zuletzt: {{this.seen_at_desc.[0]}}<br>
                                    {{this.seen_at_desc.length}}x seit Start </span>
                                {{#if this.has_submission}}
                                    <span class="badge text-bg-success small text-wrap text-end"
                                          title="{{submissionTooltip this.submissions}}"> Abgabe </span>
                                {{/if}}
                            </div>
                        </div>
                    </summary>
                    <div class="card-body mt-0 pt-2 border-top flex-grow-1">
                        <h6 class="text-center w-100 mb-1 text-uppercase fw-bold small">Historie</h6>
                        <div class="row g-1">
                            <div class="col-12">
                                <div class="fw-bold text-center mb-1 small text-primary">Cookies</div>
                                <ul class="list-group list-group-flush small rounded overflow-auto mb-1"
                                    style="max-height: 80px;">
                                    {{#each this.cookie_presents}}
                                        <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                            <span>{{this.at}}</span>
                                            <span class="fw-semibold ms-2 text-break">
                                                {{#if this.user}}
                                                    {{this.user.name}}
                                                {{else}} Unbekannt {{/if}}
                                            </span>
                                        </li>
                                    {{/each}}
                                </ul>
                            </div>
                            <div class="col-12">
                                <div class="fw-bold text-center mb-1 small text-primary">Registrierungen</div>
                                <ul class="list-group list-group-flush small rounded overflow-auto mb-1"
                                    style="max-height: 80px;">
                                    {{#each this.registrations}}
                                        <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                            <span>{{this.at}}</span>
                                            <span class="fw-semibold ms-2 text-break">
                                                {{#if this.user}}
                                                    {{this.user.name}}
                                                {{else}} Unbekannt {{/if}}
                                            </span>
                                        </li>
                                    {{/each}}
                                </ul>
                            </div>
                            {{#if this.submissions.length}}
                                <div class="col-12">
                                    <div class="fw-bold text-center mb-1 small text-primary">Abgaben</div>
                                    <ul class="list-group list-group-flush small rounded overflow-auto mb-1"
                                        style="max-height: 80px;">
                                        {{#each this.submissions}}
                                            <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                                <span>{{this.at}}</span>
                                                <span class="fw-semibold ms-2 text-break">{{this.filename}}</span>
                                            </li>
                                        {{/each}}
                                    </ul>
                                </div>
                            {{/if}}
                            <div class="col-12">
                                <div class="fw-bold text-center mb-1 small text-primary">IP: {{this.ip}} ({{this.seen_at_desc.length}}x seit Start)
                                </div>
                                <ul class="list-group list-group-flush small rounded overflow-auto"
                                    style="max-height: 80px;">
                                    {{#each this.seen_at_desc }}
                                        <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                            <span>{{this}}</span>
                                        </li>
                                    {{/each}}
                                </ul>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        {{else}}
            <div class="col-12 text-center fst-italic py-2">Keine registrierten IP-Adressen in diesem Zeitraum gefunden.</div>
        {{/each}}
    </div>
    <!-- Table 2: IPs without registered names -->
    <h5 class="text-center mt-3 mb-1 fw-bold text-uppercase border-bottom pb-1 d-inline-block mx-auto border-secondary"
        style="letter-spacing: 0.05em;">Unbekannte IP-Adressen</h5>
    <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3 g-1 mt-1">
        {{#each ips_without_name}}
            <div class="col">
                <details class="h-100 card shadow-sm mb-0 d-flex flex-column">
                    <summary class="card-header bg-transparent border-0 fw-bold py-2 px-2">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <div class="d-flex align-items-center gap-1 overflow-hidden">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-bg-secondary"
                                     style="width: 26px; height: 26px; font-size: 0.875rem;"> ? </div>
                                <div class="overflow-hidden">
                                    <span class="d-block text-truncate">{{this.ip}}</span>
                                    <span class="fw-normal small">Unbekannt</span>
                                </div>
                            </div>
                            <div class="badge bg-light text-dark border ms-1 flex-shrink-0 small">
                                {{this.seen_count}}x
                            </div>
                        </div>
                        <div class="fw-normal mt-0 text-end small"> zuletzt: {{this.seen_at_desc.[0]}}
                        </div>
                    </summary>
                    <div class="card-body mt-0 pt-2 border-top flex-grow-1">
                        <h6 class="text-center w-100 mb-1 text-uppercase fw-bold small">Historie</h6>
                        <div class="row g-1">
                            <div class="col-12">
                                <div class="fw-bold text-center mb-1 small">Kein Benutzer</div>
                                <p class="text-center fst-italic mb-1 small">Für diese IP wurde kein aktueller Cookie-Besuch gefunden.</p>
                            </div>
                            {{#if this.registrations.length}}
                                <div class="col-12">
                                    <div class="fw-bold text-center mb-1 small text-primary">Registrierungen</div>
                                    <ul class="list-group list-group-flush small rounded overflow-auto mb-1"
                                        style="max-height: 80px;">
                                        {{#each this.registrations}}
                                            <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                                <span>{{this.at}}</span>
                                                <span class="fw-semibold ms-2 text-break">
                                                    {{#if this.user}}
                                                        {{this.user.name}}
                                                    {{else}} Unbekannt {{/if}}
                                                </span>
                                            </li>
                                        {{/each}}
                                    </ul>
                                </div>
                            {{/if}}
                            <div class="col-12">
                                <div class="fw-bold text-center mb-1 small text-primary">IP: {{this.ip}}</div>
                                <ul class="list-group list-group-flush small rounded overflow-auto"
                                    style="max-height: 80px;">
                                    {{#each this.seen_at_desc }}
                                        <li class="list-group-item d-flex justify-content-between small py-1 px-2">
                                            <span>{{this}}</span>
                                            <span class="text-body-secondary fst-italic ms-2">Unbekannt</span>
                                        </li>
                                    {{/each}}
                                </ul>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        {{else}}
            <div class="col-12 text-center fst-italic py-2">Keine nicht registrierten IP-Adressen in diesem Zeitraum gefunden.</div>
        {{/each}}
    </div>
</section>