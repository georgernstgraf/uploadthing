<section class="container"
         id="admin-report-panel"
         hx-get="/admin/students"
         hx-trigger="every {{admin_refresh_seconds}}s"
         hx-target="#admin-report-panel"
         hx-swap="innerHTML"
         hx-select="#admin-report-panel > *"
         hx-include="#admin-time-filter form">
    <h2 class="text-center mb-0 fs-4">SchülerInnen und IP Adressen</h2>
    <h6 class="text-center mb-2 small"> Zeitraum: {{#unless withinTimeCutoff}}
            {{startdate}}
        {{/unless}}
        {{starttime}} - {{#if endtimeInFuture}} jetzt {{else}}
            <span x-show="showEndTime"
                  x-cloak>
                {{enddate}}
                {{endtime}}
            </span>
        {{/if}}
    </h6>
    <!-- Table 1: Student IPs -->
    <h5 class="section-heading text-center mt-2 mb-1 fw-bold text-uppercase border-bottom pb-1 d-inline-block mx-auto border-primary">
        Schüler IP-Adressen
        {{#if range_first_seen}}
        <span class="fw-normal text-body-secondary ms-2">{{range_first_seen}} – {{range_last_seen}}</span>
        {{/if}}
    </h5>
    <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3 g-1 mt-1"
         hx-disinherit="hx-select">
        {{#each ips_with_name}}
            <div class="col">
                <div class="card shadow-sm h-100"
                     style="cursor: pointer;"
                     hx-get="/admin/ip-detail?ip={{this.ip}}"
                     hx-include="#admin-time-filter form"
                     hx-target="#ip-detail-modal-content"
                     hx-trigger="click">
                    <div class="card-header bg-transparent border-0 fw-bold py-2 px-2">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <div class="d-flex align-items-center gap-1 overflow-hidden">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-primary-emphasis bg-primary-subtle"
                                     style="width: 26px; height: 26px; font-size: 0.875rem;">
                                    {{#if this.cookie_presents.[0].user}}
                                        {{givenNameInitial this.cookie_presents.[0].user.name}}
                                    {{else}} ? {{/if}}
                                </div>
                                <div class="overflow-hidden">
                                    <span class="d-block text-truncate"
                                          title="{{this.cookie_presents.[0].user.name}}">
                                        {{#if this.cookie_presents.[0].user}}
                                            {{this.cookie_presents.[0].user.name}}
                                        {{else}} Unbekannt {{/if}}
                                    </span>
                                    <span class="fw-normal d-block text-truncate small">{{this.ip}}</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1 ms-1 flex-shrink-0">
                                {{#if this.has_submission}}
                                    <span class="badge text-bg-success text-wrap text-end"
                                          title="{{submissionTooltip this.submissions}}"> Abgabe </span>
                                {{/if}}
                                     <span
                                           class="badge {{#if this.missed_count}}text-bg-warning{{else if this.is_stale}}text-bg-danger{{else}}text-bg-light{{/if}} text-wrap text-end">
                                     Fehlte {{this.missed_count}} mal </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {{else}}
            <div class="col-12 text-center fst-italic py-2">Keine registrierten IP-Adressen in diesem Zeitraum gefunden.</div>
        {{/each}}
    </div>
    <!-- Table 2: Teacher IPs -->
    <h5 class="section-heading text-center mt-3 mb-1 fw-bold text-uppercase border-bottom pb-1 d-inline-block mx-auto border-warning">
        Lehrende IP-Adressen
        {{#if range_first_seen}}
        <span class="fw-normal text-body-secondary ms-2">{{range_first_seen}} – {{range_last_seen}}</span>
        {{/if}}
    </h5>
    <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3 g-1 mt-1"
         hx-disinherit="hx-select">
        {{#each teacher_ips}}
            <div class="col">
                <div class="card shadow-sm h-100"
                     style="cursor: pointer;"
                     hx-get="/admin/ip-detail?ip={{this.ip}}"
                     hx-include="#admin-time-filter form"
                     hx-target="#ip-detail-modal-content"
                     hx-trigger="click">
                    <div class="card-header bg-transparent border-0 fw-bold py-2 px-2">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <div class="d-flex align-items-center gap-1 overflow-hidden">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-warning-emphasis bg-warning-subtle"
                                     style="width: 26px; height: 26px; font-size: 0.875rem;">
                                    {{#if this.cookie_presents.[0].user}}
                                        {{givenNameInitial this.cookie_presents.[0].user.name}}
                                    {{else}} ? {{/if}}
                                </div>
                                <div class="overflow-hidden">
                                    <span class="d-block text-truncate"
                                          title="{{this.cookie_presents.[0].user.name}}">
                                        {{#if this.cookie_presents.[0].user}}
                                            {{this.cookie_presents.[0].user.name}}
                                        {{else}} Unbekannt {{/if}}
                                    </span>
                                    <span class="fw-normal d-block text-truncate small">{{this.ip}}</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1 ms-1 flex-shrink-0">
                                {{#if this.has_submission}}
                                    <span class="badge text-bg-success text-wrap text-end"
                                          title="{{submissionTooltip this.submissions}}"> Abgabe </span>
                                {{/if}}
                                     <span
                                           class="badge {{#if this.missed_count}}text-bg-warning{{else if this.is_stale}}text-bg-danger{{else}}text-bg-light{{/if}} text-wrap text-end">
                                     Fehlte {{this.missed_count}} mal </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {{else}}
            <div class="col-12 text-center fst-italic py-2">Keine Lehrenden-IPs in diesem Zeitraum gefunden.</div>
        {{/each}}
    </div>
    <!-- Table 3: IPs without registered names -->
    <h5 class="section-heading text-center mt-3 mb-1 fw-bold text-uppercase border-bottom pb-1 d-inline-block mx-auto border-secondary">Unbekannte IP-Adressen</h5>
    <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3 g-1 mt-1"
         hx-disinherit="hx-select">
        {{#each ips_without_name}}
            <div class="col">
                <div class="card shadow-sm h-100"
                     style="cursor: pointer;"
                     hx-get="/admin/ip-detail?ip={{this.ip}}"
                     hx-include="#admin-time-filter form"
                     hx-target="#ip-detail-modal-content"
                     hx-trigger="click">
                    <div class="card-header bg-transparent border-0 fw-bold py-2 px-2">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <div class="d-flex align-items-center gap-1 overflow-hidden">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-secondary-emphasis bg-secondary-subtle"
                                     style="width: 26px; height: 26px; font-size: 0.875rem;"> ? </div>
                                <div class="overflow-hidden">
                                    <span class="d-block text-truncate">{{this.ip}}</span>
                                    <span class="fw-normal small">Unbekannt</span>
                                </div>
                            </div>
                            <div class="badge bg-light text-dark border ms-1 flex-shrink-0">
                                {{this.report_count}}x
                            </div>
                        </div>
                        <div class="fw-normal mt-0 text-end small"> zuletzt: {{this.seen_at_desc.[0]}}
                        </div>
                    </div>
                </div>
            </div>
        {{else}}
            <div class="col-12 text-center fst-italic py-2">Keine nicht registrierten IP-Adressen in diesem Zeitraum gefunden.</div>
        {{/each}}
    </div>
</section>
