<main id="app-main"
      class="container px-2 pb-2">
    <div id="app-loading-indicator"
         class="htmx-indicator position-fixed top-50 start-50 translate-middle z-3"
         aria-hidden="true">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body d-flex align-items-center gap-3 px-4 py-3">
                <div class="spinner-border text-primary"
                     role="status"
                     aria-label="Lädt"></div>
                <span class="fw-semibold">Wird geladen ...</span>
            </div>
        </div>
    </div>
    {{> nav}}
    {{> userbadge}}
    <div id="app-ip-banner" class="text-center mb-2 opacity-50">
        <span class="small text-uppercase text-body-secondary">Meine IP: {{remote_ip}}</span>
    </div>
    <div id="app-content">{{{content}}}</div>
</main>
