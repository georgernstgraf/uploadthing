<div x-data="{ fileName: 'Datei hier ablegen oder klicken' }">
    <form hx-post="/upload"
          enctype="multipart/form-data"
          hx-target="#app-content"
          hx-swap="innerHTML"
          class="card shadow-sm border-0 needs-validation mx-auto w-100 col-lg-8 col-xl-6"
          novalidate="">
        <div class="card-body text-center">
            <div class="mb-4 d-inline-block p-4 rounded-circle bg-white shadow-sm text-primary">
                <img src="/static/img/icons/cloud-arrow-up.svg"
                     alt=""
                     width="48"
                     height="48">
            </div>
            <h2 class="card-title h3 mb-2 fw-bold">
                {{~#if types_label~}} Bitte {{types_label}} Datei auswählen
                {{else}} Bitte ZIP Datei auswählen {{~/if~}}
            </h2>
            <div class="mt-4 p-4 border border-2 border-dashed rounded-4 position-relative bg-body-tertiary shadow-sm"
                 @dragover.prevent="$el.style.borderColor = 'var(--bs-primary)'"
                 @dragleave.prevent="$el.style.borderColor = 'var(--bs-border-color)'"
                 @drop.prevent="$refs.fileInput.files = $event.dataTransfer.files; $el.style.borderColor = 'var(--bs-border-color)'; fileName = $refs.fileInput.files[0]?.name || 'Datei hier ablegen oder klicken'">
                <input type="file"
                       x-ref="fileInput"
                       class="form-control position-absolute top-0 start-0 w-100 h-100 opacity-0 cursor-pointer"
                       name="file"
                       accept="{{#if accept_attr}}{{accept_attr}}{{else}}.zip{{/if}}"
                       required
                       @change="fileName = $el.files[0]?.name || 'Datei hier ablegen oder klicken'">
                <div class="d-flex align-items-center justify-content-center gap-2 fw-bold">
                    <span x-text="fileName"></span>
                </div>
            </div>
            <div class="invalid-feedback">
                {{~#if types_feedback~}} Bitte eine {{types_feedback}} Datei auswählen.
                {{else}} Bitte eine ZIP-Datei auswählen. {{~/if~}}
            </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-0 pb-4">
            <button type="submit"
                    class="btn btn-info btn-lg py-3 shadow-sm w-100 d-flex justify-content-center">
                <span class="fw-bold d-block text-center mx-auto">Hochladen</span>
                <span class="htmx-indicator">
                    <span class="spinner-border spinner-border-sm"
                          role="status"
                          aria-hidden="true"></span> Wird hochgeladen... </span>
            </button>
        </div>
    </form>
</div>
