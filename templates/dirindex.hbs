<section class="mx-3"
          style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 500px)); gap: 1.5rem; justify-content: center;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-0 text-center pt-4 pb-2">
            <h2 class="card-title mb-0"><span class="border-bottom border-3 pb-2">Angabe und Unterlagen</span></h2>
        </div>
        <div class="card-body pt-3">
        <ul class="list-group list-group-flush text-center gap-3">
            {{#each files}}
                <li class="list-group-item border-0 px-0 py-0 bg-transparent">
                    <a href="../unterlagen/{{this}}"
                        class="btn btn-info py-2 text-truncate shadow-sm fw-bold w-100">
                        {{this}}
                    </a>
                </li>
            {{/each}}
        </ul>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-0 text-center pt-4 pb-2">
            <h2 class="card-title mb-0"><span class="border-bottom border-3 border-danger pb-2">Dokumentation online</span></h2>
        </div>
        <div class="card-body pt-3">
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a href="https://getbootstrap.com/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-bootstrap.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">Bootstrap </a>
            <a href="https://learn.microsoft.com/en-us/dotnet/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-dotnet.ico"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">C# / .NET </a>
            <a href="https://css-tricks.com/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-css-tricks.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">CSS Tricks </a>
            <a href="https://fakerjs.dev/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-faker.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">Faker JS </a>
            <a href="https://docs.oracle.com/en/java/javase/21/docs/api/index.html"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-java.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">Javadoc </a>
            <a href="https://developer.mozilla.org/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-mdn.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">Mozilla Developer Network </a>
            <a href="https://www.prisma.io/docs/orm"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-prisma.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">Prisma </a>
            <a href="https://www.w3schools.com/"
               class="btn btn-sm btn-info rounded-pill text-uppercase fw-semibold"
               target="_blank"
               rel="noopener noreferrer">
                <img src="/static/img/doc-w3schools.svg"
                     alt=""
                     width="16"
                     height="16"
                     class="d-inline-block flex-shrink-0 rounded-1">W3Schools </a>
        </div>
        </div>
    </div>
</section>
