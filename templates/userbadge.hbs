<div id="user-badge-wrapper"
     hx-boost="true"
     hx-target="#main-content"
     class="d-flex justify-content-center mb-2">
    <a href="/whoami"
       class="user-badge-card card shadow-sm border-0 text-reset text-decoration-none">
        {{#if remote_user}}
            <div class="user-badge-row card-body py-2 px-3">
                <div class="user-badge-avatar rounded-circle d-inline-flex align-items-center justify-content-center text-bg-primary fw-bold">
                    {{givenNameInitial remote_user.name}}
                </div>
                <div class="user-badge-body text-start">
                    <span class="fw-bold lh-sm">{{remote_user.name}}</span>
                    <span class="small">{{remote_user.email}} / {{remote_user.klasse}}</span>
                </div>
                <span class="user-badge-action badge text-bg-light rounded-pill">Ändern</span>
            </div>
        {{else}}
            <div class="card-body py-2 px-3 text-center">
                <span class="text-danger fw-bold">Bitte Name bekanntgeben!</span>
            </div>
        {{/if}}
    </a>
</div>
