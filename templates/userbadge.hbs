<div id="user-badge-wrapper"
     hx-boost="true"
     hx-target="#main-content"
     class="d-flex justify-content-center mb-2">
    <a href="/whoami"
        class="card shadow-sm border-0 text-reset text-decoration-none w-100"
        style="max-width: 100%; min-width: 300px;">
        {{#if remote_user}}
            <div class="card-body d-flex align-items-center justify-content-between gap-3 py-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-bg-primary fw-bold"
                         style="width: 36px; height: 36px;">
                        {{givenNameInitial remote_user.name}}
                    </div>
                    <div class="d-flex flex-column text-start">
                        <span class="fw-bold">{{remote_user.name}}</span>
                        <span class="text-muted small">{{remote_user.email}} / {{remote_user.klasse}}</span>
                    </div>
                </div>
                <span class="badge text-bg-light">Change</span>
            </div>
        {{else}}
            <div class="card-body py-3">
                <span class="text-danger fw-bold">Bitte Name bekanntgeben!</span>
            </div>
        {{/if}}
    </a>
</div>
